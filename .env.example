# Copy to .env and fill in. docker-compose reads it automatically.

# Public host port (the port nginx listens on).
WHODAT_PORT=8080

# GitHub OAuth App client ID (device flow only — no client secret needed).
# Create one at https://github.com/settings/developers (OAuth App, "Enable
# Device Flow" turned on). Leave blank to disable /api/auth/github/* (returns 503).
# If Infisical is enabled and serves `GitHub__ClientId`, this can stay blank.
GITHUB_CLIENT_ID=

# --- Infisical (optional) ---
# Pull other secrets from an Infisical project at startup. When INFISICAL_ENABLED
# is true, the API uses Universal Auth (machine identity) to fetch all secrets
# under SECRET_PATH and merges them into the configuration tree. Secret keys use
# `__` for nesting — e.g. a secret named `GitHub__ClientId` populates
# Configuration["GitHub:ClientId"].
INFISICAL_ENABLED=false
INFISICAL_SITE_URL=https://secrets.voidcube.cloud
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=prod
INFISICAL_SECRET_PATH=/
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
