# Normalize all text files to LF in the repo, regardless of contributor OS.
# `text=auto` lets git auto-detect; `eol=lf` forces LF on checkout.
* text=auto eol=lf

# Explicit text — survives any auto-detect misfire.
*.rs       text eol=lf
*.toml     text eol=lf
*.cs       text eol=lf
*.csproj   text eol=lf
*.slnx     text eol=lf
*.json     text eol=lf
*.xml      text eol=lf
*.nuspec   text eol=lf
*.rb       text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.js       text eol=lf
*.ts       text eol=lf
*.sh       text eol=lf
*.ps1      text eol=lf
*.conf     text eol=lf
*.txt      text eol=lf
Dockerfile text eol=lf
.gitignore       text eol=lf
.gitattributes   text eol=lf
.editorconfig    text eol=lf
.dockerignore    text eol=lf
.env.example     text eol=lf

# Binary types — never normalize.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.svg      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.tgz      binary
*.tar      binary
*.7z       binary
*.exe      binary
*.dll      binary
*.so       binary
*.dylib    binary
*.pfx      binary
*.p12      binary
